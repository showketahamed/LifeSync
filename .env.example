# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the pooler URL for runtime connections and the direct URL for migrations.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Reserved for the upcoming Auth.js implementation. Generate a unique value.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Public values may be used only after a browser-side Supabase integration is added.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

